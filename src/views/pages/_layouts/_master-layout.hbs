<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="description"
    content="Manage — a responsive task planner dashboard UI. Component-based Handlebars templates, modular SCSS/BEM architecture, custom form controls, CSS masonry grid layout">
  <meta name="keywords" content="task management, planner, dashboard, frontend, SCSS, BEM, Handlebars, Webpack">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://maria-kapiturko-manage.vercel.app/">
  <meta property="og:title" content="{{title}} | Manage">
  <meta property="og:description"
    content="Responsive task planner dashboard UI — Handlebars, SCSS/BEM, vanilla JS, Webpack 4">
  <meta property="og:image" content="https://maria-kapiturko-manage.vercel.app/content/images/website/og-preview.jpg">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{title}} | Manage">
  <meta name="twitter:description"
    content="Responsive task planner dashboard UI — Handlebars, SCSS/BEM, vanilla JS, Webpack 4">
  <meta name="twitter:image" content="https://maria-kapiturko-manage.vercel.app/content/images/website/og-preview.jpg">

  <title>{{title}} | Manage</title>

  <link href="content/css/styles.css" rel="stylesheet">

  <script defer src="https://kit.fontawesome.com/e5b047fdd5.js" crossorigin="anonymous"></script>
  <script defer src="content/js/runtime.js"></script>
  <script defer src="content/js/vendors.js"></script>
  <script defer src="content/js/app.js"></script>
</head>

<body>
  {{#block "body"}}
  {{/block}}
  {{#block "scripts"}}
  {{/block}}
</body>

</html>
