<article class="card__item card__item--{{card-size}} card__item--{{card-bg}}">
  {{#if period-text}}<p class="card__period">{{period-text}}</p>{{/if}}
  {{#if card-image}}<img class="card__image {{#if image-small}}card__image--small{{/if}}{{#if image-large}}card__image--large{{/if}}" src="{{image-link}}" alt="{{title-text}}">{{/if}}
  <div class="card__description">
    <h2 class="card__title">{{title-text}}</h2>
    <div class="card__subtitle">
      <time class="card__date" datetime="{{date-time}}">{{date}}</time>
      {{#if card-time}}<span class="card__time">{{time}}</span>{{/if}}
    </div>
    {{#if card-link}}<a class="card__link" href="{{link}}">{{link}}</a>{{/if}}
  </div>
</article>

{{!--
  card-small -> the card size is small
  card-large -> the card size is large

  bg-white -> white background
  bg-pink -> pink background

  period-text -> period text (displayed as <p>, not a heading)

  card-image -> the image is exists

  image-small -> the image size is small
  image-large -> the image size is large

  image-link -> link to the image

  title-text -> card title text (h2 — first heading in article context)

  date-time -> date format for the datetime attribute

  date -> date text

  card-time -> the time is exists

  time -> time text

  card-link -> the link is exists

  link - link address
--}}
